{
  "expo": {
    "name": "Orbyt",
    "scheme": "orbyt",
    "slug": "ReactNativeApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/MainLogoONLY.png",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/images/MainLogoONLY.png",
      "resizeMode": "contain",
      "backgroundColor": "#030B18"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.orbyt.app",
      "icon": "./assets/images/MainLogoONLY.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/MainLogoONLY.png",
        "backgroundColor": "#030B18",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.orbyt.app",
      "versionCode": 1
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/MainLogoONLY.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/MainLogoONLY.png",
          "resizeMode": "contain",
          "backgroundColor": "#030B18",
          "android": {
            "resizeMode": "contain"
          }
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.793742543220-bnrhm15pgnjs5b1evvadu2tpjjk6pv6m"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "397c1cc6-f5d4-4ba9-be3b-aaa45d34aa10"
      }
    },
    "owner": "harshjhasd"
  }
}
